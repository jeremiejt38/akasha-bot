DEBUG=false
BOT_NAME=Akasha
DISCORD_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ADMIN_ID=
DATABASE_PATH=./data/bot.db
TELEGRAM_TOKEN=
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
WHATSAPP_SERVICE_URL=http://whatsapp:3001
# Pour le mode host (sans Docker), remplacez par http://localhost:3001
BRIDGE_API_TOKEN=
BRIDGE_WEBHOOK_URL=http://bot:8000/webhooks/whatsapp
# Pour le mode host, remplacez par http://localhost:8000/webhooks/whatsapp

# WhatsApp low-power / energy settings
WA_LOW_POWER=true
WA_SKIP_MEDIA=false
WA_MESSAGE_PROCESS_DELAY_MS=0
WA_JS_HEAP_MB=512
# WA_PUPPETEER_ARGS= (optional, comma-separated Chromium flags)

MAX_ATTACHMENT_MEMORY_MB=5
MAX_MESSAGE_LENGTH=2000
INBOX_CATEGORY_NAME=📥 INBOX
CHANNEL_MARKER_WA=🟢
CHANNEL_MARKER_TL=🔵
CHANNEL_MARKER_IG=🟣
CHANNEL_MARKER_FB=🔷
CHANNEL_MARKER_SC=🟡
CHANNEL_MARKER_TK=🔴
CHANNEL_MARKER_DC=🟠
META_GRAPH_BASE_URL=https://graph.facebook.com/v20.0
META_PAGE_ACCESS_TOKEN=
META_VERIFY_TOKEN=
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_ENABLED=true
INSTAGRAM_BUSINESS_ACCOUNT_ID=
MESSENGER_ENABLED=false
FACEBOOK_PAGE_ID=

# Optional bridge services for platforms without public DM APIs
SNAPCHAT_SERVICE_URL=
TIKTOK_SERVICE_URL=

# Wizarr integration (user & invitation management)
WIZARR_BASE_URL=
WIZARR_API_KEY=
WIZARR_INVITE_SERVER_IDS=1,2
WIZARR_INVITE_EXPIRES_DAYS=7
TRIAL_DURATION_DAYS=14
AKASHA_INVITE_URL=https://akasha.ing

# Overseerr integration (request media management)
OVERSEERR_BASE_URL=
OVERSEERR_API_KEY=

# Tracearr integration (trust score and streaming stats)
TRACEARR_BASE_URL=
TRACEARR_API_KEY=

# Auto-responder (fuzzy matching on inbound messages)
AUTO_RESPONDER_ENABLED=false
AUTO_RESPONDER_THRESHOLD=80
AUTO_RESPONDER_DATA_PATH=./config/auto_responses.json

# Onboarding / member role
ONBOARDING_DM_ENABLED=true
MEMBER_ROLE_NAME=Abonné
CREATE_MEMBER_ROLE=true
SEERR_SIGNUP_URL=https://s.akasha.ing
SUPPORT_DM_ENABLED=true

# Expiration alerts
EXPIRATION_WARNING_DAYS=7
EXPIRATION_ALERT_HOUR=9
EXPIRATION_NOTIFY_SUBSCRIBERS=true

# Health check URLs for connection diagnostics
PLEX_URL=https://p.akasha.ing
SEERR_URL=https://seerr.akasha.ing
JELLYFIN_URL=https://j.akasha.ing
WEBSITE_URL=https://akasha.ing
